# API Keys (get your own from providers)
GEMINI_API_KEY=your_gemini_api_key_here

# Yandex Wordstat API credentials
YANDEX_CLIENT_ID=your_yandex_client_id_here
YANDEX_CLIENT_SECRET=your_yandex_client_secret_here
YANDEX_OAUTH_TOKEN=your_yandex_oauth_token_here

# Yandex Metrika (analytics & traffic-driven content)
# Get counter ID from metrika.yandex.ru → your counter → settings → counter number
YANDEX_METRIKA_COUNTER_ID=your_counter_id_here

# SEO Audit
# Minimum SEO score for article to pass audit (0-100)
SEO_MIN_SCORE=80
